#, python-brace-format
msgid "{duty}% power"
msgstr "{duty}% de potência"

#: liquidctl_gui/ui/page_dashboard.py:165
#, python-brace-format
msgid "Fan {n}: {rpm} RPM / {duty}%"
msgstr "Ventoinha n° {n}: {rpm} RPM / {duty}%"

