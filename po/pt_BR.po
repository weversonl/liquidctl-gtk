msgid "Speed"
msgstr "Velocidade"

#: liquidctl_gui/ui/page_lighting.py:161
msgid "Brightness"
msgstr "Brilho"

#: liquidctl_gui/ui/page_profiles.py:15
msgid "Prioritizes quiet operation, slightly higher temperatures"
msgstr "Prioriza silêncio, temperaturas um pouco mais altas"

#: liquidctl_gui/ui/page_profiles.py:16
msgid "Good balance between noise and cooling"
msgstr "Bom equilíbrio entre ruído e resfriamento"

#: liquidctl_gui/ui/page_profiles.py:17
msgid "Maximum cooling, more noise"
msgstr "Resfriamento máximo, mais ruído"

#: liquidctl_gui/ui/page_profiles.py:28
msgid "Custom configuration in use — none of the profiles below match it."
msgstr ""
"Configuração personalizada em uso — nenhum dos perfis abaixo corresponde a "
"ela."

#: liquidctl_gui/ui/page_profiles.py:37
msgid "New profile from current settings"
msgstr "Novo perfil a partir das configurações atuais"

#: liquidctl_gui/ui/page_profiles.py:66
msgid "Active"
msgstr "Ativo"

#: liquidctl_gui/ui/page_profiles.py:70
msgid "Apply"
msgstr "Aplicar"

#: liquidctl_gui/ui/page_profiles.py:77
msgid "Delete profile"
msgstr "Excluir perfil"

#: liquidctl_gui/ui/page_profiles.py:96
msgid "Delete profile?"
msgstr "Excluir perfil?"

#: liquidctl_gui/ui/page_profiles.py:97
#, python-brace-format
msgid "“{name}” will be permanently removed."
msgstr "“{name}” será removido permanentemente."

#: liquidctl_gui/ui/page_profiles.py:99 liquidctl_gui/ui/page_profiles.py:123
msgid "Cancel"
msgstr "Cancelar"

#: liquidctl_gui/ui/page_profiles.py:100
msgid "Delete"
msgstr "Excluir"

#: liquidctl_gui/ui/page_profiles.py:118
msgid "New profile"
msgstr "Novo perfil"

#: liquidctl_gui/ui/page_profiles.py:119
msgid "Give this profile a name. It will store the current pump/fan curves."
msgstr ""
"Dê um nome a este perfil. Ele vai guardar as curvas atuais de bomba/"
"ventoinha."

#: liquidctl_gui/ui/page_profiles.py:121
msgid "Profile name"
msgstr "Nome do perfil"

#: liquidctl_gui/ui/page_profiles.py:124
msgid "Create"
msgstr "Criar"

#: liquidctl_gui/ui/page_profiles.py:130
msgid "Untitled profile"
msgstr "Perfil sem nome"

#: liquidctl_gui/ui/page_profiles.py:133
msgid "Custom profile"
msgstr "Perfil personalizado"

#: liquidctl_gui/ui/page_settings.py:30
msgid "Appearance"
msgstr "Aparência"

#: liquidctl_gui/ui/page_settings.py:31
msgid "Theme"
msgstr "Tema"

#: liquidctl_gui/ui/page_settings.py:32
msgid "System"
msgstr "Sistema"

#: liquidctl_gui/ui/page_settings.py:32
msgid "Dark"
msgstr "Escuro"

#: liquidctl_gui/ui/page_settings.py:32
msgid "Light"
msgstr "Claro"

#: liquidctl_gui/ui/page_settings.py:45
msgid "Devices"
msgstr "Dispositivos"

#: liquidctl_gui/ui/page_settings.py:46
msgid "Default device"
msgstr "Dispositivo padrão"

#: liquidctl_gui/ui/page_settings.py:47
msgid "Which device to select when the app starts"
msgstr "Qual dispositivo selecionar quando o app iniciar"

#: liquidctl_gui/ui/page_settings.py:49 liquidctl_gui/ui/page_settings.py:133
msgid "Auto (first detected)"
msgstr "Automático (primeiro detectado)"

#: liquidctl_gui/ui/page_settings.py:56
msgid "Enabled devices"
msgstr "Dispositivos habilitados"

#: liquidctl_gui/ui/page_settings.py:58
msgid "Disabled devices are never connected to or controlled by the app."
msgstr "Dispositivos desabilitados nunca são conectados nem controlados pelo app."

#: liquidctl_gui/ui/page_settings.py:63
msgid "Behavior"
msgstr "Comportamento"

#: liquidctl_gui/ui/page_settings.py:64
msgid "Start with the system"
msgstr "Iniciar com o sistema"

#: liquidctl_gui/ui/page_settings.py:67
msgid "High temperature notifications"
msgstr "Notificações de temperatura alta"

#: liquidctl_gui/ui/page_settings.py:72
msgid "Units and monitoring"
msgstr "Unidades e monitoramento"

#: liquidctl_gui/ui/page_settings.py:73
msgid "Temperature unit"
msgstr "Unidade de temperatura"

#: liquidctl_gui/ui/page_settings.py:84
msgid "Polling interval"
msgstr "Intervalo de leitura"

#: liquidctl_gui/ui/page_settings.py:96
msgid "Fan duty validation interval"
msgstr "Intervalo de validação da ventoinha"

#: liquidctl_gui/ui/page_settings.py:98
msgid ""
"How often the app double-checks that fan speeds actually match the curve. "
"Higher values use less CPU/USB traffic but take longer to catch a hardware "
"glitch."
msgstr ""
"Com que frequência o app confere se a velocidade das ventoinhas realmente "
"bate com a curva. Valores mais altos consomem menos CPU/tráfego USB, mas "
"demoram mais para detectar uma falha do hardware."

#: liquidctl_gui/ui/page_settings.py:116
msgid "About"
msgstr "Sobre"

#: liquidctl_gui/ui/page_settings.py:119
msgid ""
"This interface controls liquidctl, the open-source cross-platform tool for "
"liquid coolers, fans and RGB lighting."
msgstr ""
"Esta interface controla o liquidctl, ferramenta open-source multiplataforma "
"para refrigeração líquida, ventoinhas e iluminação RGB."

