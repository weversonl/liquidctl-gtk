msgstr "Ventoinha"

#: liquidctl_gui/ui/page_curves.py:35
msgid "Quiet"
msgstr "Silencioso"

#: liquidctl_gui/ui/page_curves.py:37
msgid "Extreme"
msgstr "Extremo"

#: liquidctl_gui/ui/page_curves.py:252
msgid "This device has no control for this channel."
msgstr "Este dispositivo não possui controle para este canal."

#: liquidctl_gui/ui/page_curves.py:258
msgid "This pump only supports fixed modes, not a temperature curve."
msgstr "Esta bomba só suporta modos fixos, não uma curva de temperatura."

#: liquidctl_gui/ui/page_curves.py:281
msgid ""
"Drag points to adjust the curve, double-click to add a point, right-click a "
"point to remove it."
msgstr ""
"Arraste os pontos para ajustar a curva, clique duplo para adicionar um "
"ponto, clique direito num ponto para removê-lo."

#: liquidctl_gui/ui/page_curves.py:286
msgid "Restore default"
msgstr "Restaurar padrão"

#: liquidctl_gui/ui/page_dashboard.py:52
msgid "Connected"
msgstr "Conectado"

#: liquidctl_gui/ui/page_dashboard.py:58
msgid "Liquid temperature"
msgstr "Temperatura do líquido"

#: liquidctl_gui/ui/page_dashboard.py:64
msgid ""
"No liquidctl devices were detected. Check USB connections and udev "
"permissions."
msgstr ""
"Nenhum dispositivo liquidctl foi detectado. Verifique as conexões USB e as "
"permissões do udev."

#: liquidctl_gui/ui/page_dashboard.py:138
#: liquidctl_gui/ui/page_dashboard.py:150
#, python-brace-format
