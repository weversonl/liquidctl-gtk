#: liquidctl_gui/ui/page_curves.py:27 liquidctl_gui/ui/page_profiles.py:17
msgid "Performance"
msgstr "Performance"

#: liquidctl_gui/ui/page_curves.py:28
msgid "Custom"
msgstr "Personalizado"

#: liquidctl_gui/ui/page_curves.py:31 liquidctl_gui/ui/page_dashboard.py:59
msgid "Pump"
msgstr "Bomba"

#: liquidctl_gui/ui/page_curves.py:31 liquidctl_gui/ui/page_dashboard.py:60
